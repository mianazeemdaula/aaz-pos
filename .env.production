# API Configuration — Production (Tauri desktop build)
# Must be an absolute URL; Tauri's origin is http://tauri.localhost, not the backend
VITE_API_BASE_URL=http://127.0.0.1:4001/api
VITE_API_TIMEOUT=30000
VITE_FBR_BASE_URL=http://localhost:8524/api/IMSFiscal
VITE_FBR_POS_ID=123456
VITE_FBR_ENABLED=true

# Environment
VITE_APP_ENV=production
