# API Configuration
VITE_API_BASE_URL=http://localhost:4001/api
VITE_API_TIMEOUT=30000

# Environment
VITE_APP_ENV=development

# FBR (Federal Board of Revenue) Tax Integration
# Base URL for FBR fiscal service
VITE_FBR_BASE_URL=http://localhost:8524/api/IMSFiscal

# Your registered POS ID with FBR (REQUIRED - Replace with your actual POS ID)
VITE_FBR_POS_ID=123456

# Enable/disable FBR integration (true/false)
VITE_FBR_ENABLED=true
