{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aazify",
  "version": "0.1.0",
  "identifier": "com.aaz.aazpointofsale",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AAZ Point of Sale",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["../public/fbr-logo-1.png"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBMUMxN0JDNTExRjU3NjQKUldSa1Z4OVJ2QmNjdW5LRGdQTXFIVnFrT1JlL3pxWEx1RE5xbnh3MGg3OHhkY1NzMWQvMUxlZlMK",
      "endpoints": [
        "https://github.com/mianazeemdaula/aaz-point-of-sale/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
